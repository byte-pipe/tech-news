"""
Critical failure mode testing focused on the most important error scenarios.
Tests only the essential failure modes to avoid long test runs.
"""

import os
import sys
import tempfile
import unittest
from pathlib import Path
from unittest.mock import patch

# Add the parent directory to the Python path
sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), "..")))

from core.config import ScraperConfig, set_config
from core.scraper_registry import ScraperRegistry
from core.scraper_runner import run_scraper


class TestCriticalFailureModes(unittest.TestCase):
    """Test critical failure modes that must be handled gracefully."""

    def setUp(self):
        """Set up test environment."""
        self.temp_dir = tempfile.TemporaryDirectory()
        self.project_root = Path(self.temp_dir.name)

        # Create project structure
        (self.project_root / "src" / "scraper" / "config").mkdir(parents=True)
        (self.project_root / "pyproject.toml").touch()

        sites_config = """
github:
  url: "https://github.com/trending"
  selector: ".Box-row"
  fields:
    title: "h1 a"
    url: "h1 a@href"
"""
        (self.project_root / "src" / "scraper" / "config" / "sites.yaml").write_text(sites_config)

        self.config = ScraperConfig(str(self.project_root))
        set_config(self.config)

    def tearDown(self):
        """Clean up."""
        self.temp_dir.cleanup()

    def test_network_failure_graceful_handling(self):
        """Test that network failures don't crash the scraper."""
        scrapers = ScraperRegistry.get_scrapers_for_names(["github"])
        scraper_class = scrapers[0]

        # Mock _get_page to return None (simulating network failure)
        with patch.object(scraper_class, "_get_page", return_value=None):
            result = run_scraper(scraper_class, output_format="json", dry_run=True, fetch_content=False)

            # Should return False, not crash
            self.assertFalse(result)

    def test_malformed_html_handling(self):
        """Test handling of malformed or empty HTML."""
        scrapers = ScraperRegistry.get_scrapers_for_names(["github"])
        scraper_class = scrapers[0]

        # Mock _get_page to return empty HTML
        with patch.object(scraper_class, "_get_page", return_value=""):
            result = run_scraper(scraper_class, output_format="json", dry_run=True, fetch_content=False)

            # Should handle empty HTML gracefully
            self.assertIsInstance(result, bool)

    def test_file_permission_errors(self):
        """Test handling of file permission errors."""
        scrapers = ScraperRegistry.get_scrapers_for_names(["github"])
        scraper_class = scrapers[0]

        # Mock open to raise PermissionError
        with patch("builtins.open", side_effect=PermissionError("Permission denied")):
            result = run_scraper(scraper_class, output_format="json", dry_run=False, fetch_content=False)  # Need to try writing files

            # Should handle permission errors gracefully
            self.assertFalse(result)

    def test_directory_creation_failure(self):
        """Test recovery when directory creation fails."""
        # Mock os.makedirs to fail
        with patch("os.makedirs", side_effect=PermissionError("Permission denied")):
            with self.assertRaises(RuntimeError):
                # This should fail fast as expected behavior
                self.config.ensure_date_structure("2025-06-01")

    def test_selector_not_found_graceful_degradation(self):
        """Test graceful handling when selectors don't match anything."""
        scrapers = ScraperRegistry.get_scrapers_for_names(["github"])
        scraper_class = scrapers[0]

        # Mock _get_page to return HTML without matching selectors
        html_without_matches = "<html><body><p>No matching elements</p></body></html>"
        with patch.object(scraper_class, "_get_page", return_value=html_without_matches):
            result = run_scraper(scraper_class, output_format="json", dry_run=True, fetch_content=False)

            # Should complete without crashing, even with no data
            self.assertIsInstance(result, bool)


if __name__ == "__main__":
    unittest.main()
